## output qq plots 
predictors <- c("ANI_log", "COTT_log", "OMTD_log", "CA4_log", "OANSD_log", "MDA44_log", "sumaa_log")
outcomes <- c("novelty.pref.faces_b1_b2", "trial.duration.faces_b1_b2", "avg.run.duration.comb.faces_b1_b2", "shift.rate.faces_b1_b2")

make_qqplots <- function(data, predictors, outcomes) {
  
  plots <- list()
  
  for (out in outcomes) {
    for (pred in predictors) {
      
      # model formula
      formula <- as.formula(
        paste(out, "~", pred,
              "+ sex + set + cohort + age.vrm.test + mat_age + mat_educ + ppbmi + urine_sp_gravity")
      )
      
      # fit model
      model <- lm(formula, data = amines_vrm)
      
      # plot title
      plot_name <- paste0("QQplot_", out, "_vs_", pred)
      
      # create QQ plot object
      p <- ggplot(data.frame(resid = residuals(model)), aes(sample = resid)) +
        stat_qq() +
        stat_qq_line() +
        ggtitle(paste("QQ Plot:", out, "vs", pred)) +
        theme_bw()
      
      # store in list
      plots[[plot_name]] <- p
    }
  }
  
  return(plots)
}

qqplots <- make_qqplots(
  data = amines_vrm,
  predictors = predictors,
  outcomes = outcomes
)
