#### BKMR 

# define mixture
mix <- amines_vrm %>% select(ANI_log, COTT_log, OMTD_log, CA4_log, OANSD_log, MDA44_log, novelty.pref.faces_b1_b2, trial.duration.faces_b1_b2, avg.run.duration.comb.faces_b1_b2, shift.rate.faces_b1_b2, sex, age.vrm.test, cohort, mat_age, mat_educ, ppbmi, urine_sp_gravity) %>%
  drop_na()

# define exposures
df.exp <- mix %>% dplyr::select(ANI_log, COTT_log, OMTD_log, CA4_log, OANSD_log, MDA44_log)


# Rename exposures for easy plotting
df.exp <- df.exp %>% rename(aniline = ANI_log, 
                            cotinine = COTT_log, 
                            'o/m-toluidine' = OMTD_log, # has 0 values
                            '4-chloroaniline' = CA4_log, 
                            "o-anisidine" = OANSD_log, 
                            "4'4methylenedianiline" = MDA44_log)

# create dummy varaibles for factor varaibles since BKMR models need to be numeric
mix$sex<-ifelse(mix$sex==2,1,0)
mix$cohort<-ifelse(mix$cohort==2,1,0)
mix$hs<-ifelse(mix$mat_educ==1,1,0)
mix$grad<-ifelse(mix$mat_educ==3,1,0)
mix$cohort<-ifelse(mix$cohort=='CIOB',1,0)

# define covariates
df.cov <- mix %>% dplyr::select(sex, ppbmi, age.vrm.test, # cohort,
                                urine_sp_gravity, mat_age, hs, grad)

df.cov <- sapply(df.cov, as.numeric)


set.seed(142)

# run bkmr
fit_sr <- kmbayes(y = mix$shift.rate.faces_b1_b2,
                Z = df.exp,
                X = df.cov,
                iter = 1000, 
                verbose = FALSE, 
                varsel = TRUE,
                family='gaussian')

# extract PIPS
pips_sr <- ExtractPIPs(fit_sr)
pips_sr <- pips_sr %>% mutate(outcome = "Shift Rate")

# overall plot
risks.overall_sr <- OverallRiskSummaries(fit = fit_sr, y = mix$shift.rate.faces_b1_b2, Z =  df.exp, X = df.cov, 
                                      qs = seq(0.25, 0.75, by = 0.05), 
                                      q.fixed = 0.5, method = "exact")

# univariate plot
pred.resp.univar_sr <- PredictorResponseUnivar(fit = fit_sr)

# single var plot
risks.singvar_sr <- SingVarRiskSummaries(fit = fit_sr, y = mix$shift.rate.faces_b1_b2, Z = df.exp, X = df.cov, 
                                      qs.diff = c(0.25, 0.75), 
                                      q.fixed = c(0.25, 0.50, 0.75),
                                      method = "exact")
