```{r class.output="scroll-400", warning = F, message = F}
#### Calculate geometric mean and geometric sd across grouped variables

bde_names <- c("sumaa", "ANI", "COTT", "OMTD", "CA4", "OANSD", "MDA44")
demo_names <- c("marital", "mat_educ", "mat_race_eth", "parity")

# format 
dist_amines_demo <- amines_vrm %>%
    mutate(sex = recode(sex,
                      "1" = "Male",
                      "2" = "Female"),
         mat_educ = recode(mat_educ,
                      "1" = "<College Degree",
                      "2" = "College degree",
                      "3" = "Graduate degre"),
         marital = recode(marital,
                      "1" = "Married/living together",
                      "2" = "Single"),
         mat_race_eth = recode(mat_race_eth,
                               "1" = "White",
                               "2" = "Black/Multi racial",
                               "3" = "Asian, native hawaiian, pacific islander, american indian, alaska native",
                               "4" = "Hispanic"),
         parity = recode(parity,
                         "0" = "No prior births",
                         "1" = "1 or more prior births")) %>%
  select(all_of(bde_names), all_of(demo_names)) %>%
  pivot_longer(cols = all_of(demo_names), names_to = "stress_var", values_to = "stress_group") %>%
  pivot_longer(cols = all_of(bde_names), names_to = "bde", values_to = "value") %>%
  group_by(stress_var, stress_group, bde) %>%
  drop_na() %>%
  summarise(
    geomean = round(exp(mean(log(value), na.rm = TRUE)), 2),
    geosd   = round(exp(sd(log(value), na.rm = TRUE)), 2)) %>%
  mutate(geomean_sd = paste0(geomean, " (", geosd, ")"),
        stress_var = recode(stress_var,
