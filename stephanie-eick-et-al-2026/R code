### Pooled 

adjusted: sex + set + cohort + age.vrm.test + maternal age + maternal education + bmi + urine_sp_gravity

```{r class.output="scroll-400", warning = F, message = F, fig.height = 15, fig.width = 15}
#### Pooled regression

## Add binary indicator for cotinine
amines_vrm$COTT_binary<-ifelse(amines_vrm$COTT_comment==0,0, ifelse(amines_vrm$COTT_comment>1, 1, NA))

# loop regression over predictors and outcomes
predictors <- c("ANI_log", "COTT_log", "COTT_binary", "OMTD_log", "CA4_log", "OANSD_log", "MDA44_log", "sumaa_log")
outcomes <- c("novelty.pref.faces_b1_b2", "trial.duration.faces_b1_b2", "avg.run.duration.comb.faces_b1_b2", "shift.rate.faces_b1_b2")

models <- list()
for (i in 1:length(outcomes)) {
  for (j in 1:length(predictors)) {
    model_name <- paste0(outcomes[i], " ~ ", predictors[j])
    formula <- as.formula(paste(outcomes[i], " ~ ", predictors[j], " + sex  + cohort + age.vrm.test +  mat_age + mat_educ + ppbmi + urine_sp_gravity"))
    model <- lm(formula = formula, data = amines_vrm)
    n  <- nobs(model)
    models[[model_name]] <- tidy(model, conf.int = TRUE) %>%
      mutate(outcome = outcomes[i], N = n)
  }
}

# format
reg_pooled <- bind_rows(models, .id = "model") %>%
  filter(!term %in% c("sex2", "cohortIKIDS","age.vrm.test", "mat_age", "mat_educ2", "mat_educ3","ppbmi","urine_sp_gravity",  "(Intercept)")) %>%
  mutate(cohort = "pooled")

# format for plotting, removing the binary cotinine measure 
reg_pooled2<-reg_pooled[which(reg_pooled$term!="COTT_binary"),]

# build rectangles for shading 
term_rects <- reg_pooled2 %>%
  distinct(term) %>%
  arrange(term) %>%
  mutate(
    term_index = row_number(),
    fill_color = if_else(term_index %% 2 == 0, "grey98", "grey92")
  )

reg_pooled2 <- reg_pooled2 %>%
  left_join(term_rects, by = "term") 
    
# factor
reg_pooled2$outcome <- factor(reg_pooled2$outcome, levels = c("shift.rate.faces_b1_b2", "novelty.pref.faces_b1_b2","avg.run.duration.comb.faces_b1_b2", "trial.duration.faces_b1_b2"))

reg_pooled2$term <- factor(reg_pooled2$term, levels = rev(c("sumaa_log", "ANI_log","COTT_log", "OMTD_log", "CA4_log", "OANSD_log", "MDA44_log")))


# plot
ggplot(reg_pooled2, aes(estimate, term)) + 
  geom_rect(
    data = term_rects,
    aes(ymin = term_index - 0.5, ymax = term_index + 0.5,
        xmin = -Inf, xmax = Inf, fill = fill_color),
    inherit.aes = FALSE,
    show.legend = FALSE
  ) +
  scale_fill_identity() +
  geom_pointrange(aes(xmin = conf.low, xmax = conf.high), 
