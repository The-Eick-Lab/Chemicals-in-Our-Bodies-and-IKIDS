         marital = "Marital Status",
         mat_educ = "Education",
         mat_race_eth = "Race/Ethnicity",
         parity = "Parity")) %>%
  select(stress_var, stress_group, bde, geomean_sd) %>%
  pivot_wider(names_from = bde, values_from = geomean_sd) %>%
  gt(rowname_col = "stress_group", groupname_col = "stress_var") %>%
  cols_label(stress_group = "") %>%
  gt_theme_538() %>%
  opt_table_font(font = list(google_font(name = "Nunito")))


